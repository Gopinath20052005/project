then(data => {
    showLoading(false);

    if (data.success) {

        console.log("Audio URL:", data.audio_url);

        const audioPlayer = document.getElementById("audioPlayer");

        // 🔥 IMPORTANT FIX
        audioPlayer.src = data.audio_url + "?t=" + Date.now(); // cache remove

        audioPlayer.load();

        audioPlayer.onloadedmetadata = () => {
            console.log("Audio duration:", audioPlayer.duration);

            if (audioPlayer.duration > 0) {
                audioPlayer.play().then(() => {
                    console.log("Audio playing ✅");
                }).catch(err => {
                    console.error("Play blocked:", err);
                });
            } else {
                alert("Audio file empty or not loaded ❌");
            }
        };

        document.getElementById("audioSection").style.display = "block";

    } else {
        showError(data.error || "Audio failed");
    }
})